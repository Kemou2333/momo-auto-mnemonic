{
  "permissions": {
    "allow": [
      "Bash(git add processed.json)",
      "Bash(git commit -m *)",
      "Bash(git config *)",
      "Bash(git remote set-url origin *)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin main)",
      "Bash(python3 run_mnemonics.py*)",
      "mcp__github__get_*",
      "mcp__github__list_*",
      "mcp__github__search_*"
    ],
    "deny": [
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git push origin HEAD)",
      "Bash(git push --set-upstream*)",
      "Bash(git push -u *)",
      "Bash(git add run_mnemonics.py)",
      "Bash(git add CLAUDE.md)",
      "Bash(git add MNEMONIC_RULES.md)",
      "Bash(git add README.md)",
      "Bash(git add .claude*)",
      "Bash(git add -A)",
      "Bash(git add .)",
      "mcp__github__create_pull_request",
      "mcp__github__create_or_update_file",
      "mcp__github__push_files",
      "mcp__github__create_branch",
      "Write(CLAUDE.md)",
      "Write(MNEMONIC_RULES.md)",
      "Write(README.md)",
      "Write(.claude/settings.json)",
      "Write(scripts/gen_chart.py)"
    ]
  },
  "env": {
    "GIT_AUTHOR_NAME": "Claude Routine",
    "GIT_AUTHOR_EMAIL": "routine@claude.ai",
    "GIT_COMMITTER_NAME": "Claude Routine",
    "GIT_COMMITTER_EMAIL": "routine@claude.ai"
  }
}
