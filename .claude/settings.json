{
  "permissions": {
    "defaultMode": "deny",
    "allow": [
      "Bash(git add processed.json)",
      "Bash(git commit -m *)",
      "Bash(git config user.email *)",
      "Bash(git config user.name *)",
      "Bash(git remote set-url origin *)",
      "Bash(git push origin HEAD:main)",
      "Bash(git push origin main)",
      "Bash(python3 run_mnemonics.py)",
      "Bash(python3 run_mnemonics.py --fetch)",
      "Bash(python3 run_mnemonics.py --backfill *)",
      "Read",
      "Edit",
      "mcp__github__get_*",
      "mcp__github__list_*",
      "mcp__github__search_*"
    ],
    "deny": [
      "Bash(git branch*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git reset*)",
      "Bash(git stash*)",
      "Bash(git pull*)",
      "Bash(git fetch*)",
      "Bash(git rm*)",
      "Bash(git push origin HEAD)",
      "Bash(git push -u *)",
      "Bash(git push --set-upstream*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git add -A*)",
      "Bash(git add .)",
      "Bash(git add CLAUDE.md*)",
      "Bash(git add MNEMONIC_RULES.md*)",
      "Bash(git add CONTEXT.md*)",
      "Bash(git add README.md*)",
      "Bash(git add run_mnemonics.py*)",
      "Bash(git add .claude*)",
      "Bash(git add *.py)",
      "Bash(git add *.md)",
      "Bash(curl *)",
      "Bash(wget *)",
      "Bash(rm *)",
      "Bash(sudo *)",
      "mcp__github__create_pull_request",
      "mcp__github__create_or_update_file",
      "mcp__github__push_files",
      "mcp__github__create_branch",
      "mcp__github__delete_file",
      "mcp__github__merge_pull_request",
      "Write(CLAUDE.md)",
      "Write(MNEMONIC_RULES.md)",
      "Write(PHRASE_RULES.md)",
      "Write(CONTEXT.md)",
      "Write(README.md)",
      "Write(.claude/settings.json)",
      "Write(scripts/gen_chart.py)",
      "Write(processed.json)",
      "Write(.gitignore)"
    ]
  },
  "env": {
    "GIT_AUTHOR_NAME": "Claude Routine",
    "GIT_AUTHOR_EMAIL": "routine@claude.ai",
    "GIT_COMMITTER_NAME": "Claude Routine",
    "GIT_COMMITTER_EMAIL": "routine@claude.ai"
  }
}
